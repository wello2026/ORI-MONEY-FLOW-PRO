# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Push Notifications (VAPID key for Web Push)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# App Configuration
VITE_APP_NAME=ORI Finance Pro
VITE_APP_CURRENCY=LYD
VITE_APP_CURRENCY_SYMBOL=د.ل
VITE_APP_DATE_FORMAT=DD/MM/YYYY
VITE_APP_DECIMAL_PLACES=3

# Approval Thresholds
VITE_APPROVAL_THRESHOLD_HIGH=10000
VITE_APPROVAL_THRESHOLD_MEDIUM=5000

---
# Cloudflare Pages Deployment:
# 1. Connect GitHub repo to Cloudflare Pages
# 2. Build command: npm run build
# 3. Build output directory: dist
# 4. Environment variables (Production):
#    VITE_SUPABASE_URL
#    VITE_SUPABASE_ANON_KEY
#    VITE_VAPID_PUBLIC_KEY
# 5. Pages Functions (functions/[[path]].ts) handles SPA routing
---
# Supabase Edge Function (send-push):
# Set these in Supabase Dashboard > Edge Functions > send-push:
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   VAPID_PUBLIC_KEY
#   VAPID_PRIVATE_KEY
#   VAPID_EMAIL (mailto:your-email@example.com)